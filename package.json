{
  "name": "marp-slides",
  "version": "0.2.1",
  "description": "Export Marp presentations to PNG images with batch support",
  "main": "marp-slides.ts",
  "type": "module",
  "files": [
    "marp-slides.ts",
    "marp-video.ts"
  ],
  "scripts": {
    "start": "bun run marp-slides.ts",
    "release": "bun run scripts/release.ts",
    "release:patch": "bun run scripts/release.ts patch",
    "release:minor": "bun run scripts/release.ts minor",
    "release:major": "bun run scripts/release.ts major",
    "release:beta": "bun run scripts/release.ts patch --pre beta",
    "release:dry": "bun run scripts/release.ts --dry-run"
  },
  "keywords": [
    "marp",
    "presentation",
    "slides",
    "png",
    "export",
    "markdown"
  ],
  "author": "chris-cadev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chris-cadev/marp-slides"
  },
  "bugs": {
    "url": "https://github.com/chris-cadev/marp-slides/issues"
  },
  "homepage": "https://github.com/chris-cadev/marp-slides#readme",
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "puppeteer": "^23.0.0",
    "tinyglobby": "^0.2.15"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
